{
  "name": "smoothy-fe",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "dev:web": "turbo -F web dev",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "prepare": "lefthook install || true",
    "docker:build": "docker compose build",
    "docker:build:web": "docker build --build-arg APP_NAME=web -t smoothy/web:latest .",
    "docker:build:admin": "docker build --build-arg APP_NAME=admin -t smoothy/admin:latest .",
    "docker:build:vendor": "docker build --build-arg APP_NAME=vendor -t smoothy/vendor:latest .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@smoothy-fe/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@smoothy-fe/config": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.6",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "vitest": "^4.1.5"
  },
  "packageManager": "bun@1.3.4"
}
